{
  "fetchinfo":{
    "base":{
      "prepend_XML_declaration":false,
      "object_types":{
        "Book" : {
           "docindexfeature" : "docindex",
           "end" : "",
           "start" : "{{ setvar 'TextKind' }}Prose{{ setvarend }}"
        },
        "EmbeddedQuotation" : {
           "docindexfeature" : "docindex",
           "end" : "{{ setvar 'embedded_quotation' }}{{ setvarend }}",
           "start" : "{{ setvar 'embedded_quotation' }} embedded-quotation{{ setvarend }}"
        },
        "EmbeddedDocument" : {
           "docindexfeature" : "docindex",
           "end" : "{{ setvar 'embedded_document' }}{{ setvarend }}",
           "start" : "{{ setvar 'embedded_document' }} embedded-document{{ setvarend }}"
        },
        "Source":{
          "docindexfeature":"docindex",
          "end":"</td></tr>",
          "get":[
            "source_name",
            "source_occurrence",
            "source_color"
          ],
          "start":"\
<tr id=\"source-{{ feature 0 }}-{{ feature 1 }}\" class=\"source{{ featurenomangle 2 }}\">\n\
<td class=\"sourceTitle\">{{ feature 0 }} {{ featurenomangle 1 }}</td>\n\
<td class=\"sourceText\">\n"
        },
        "NonCanonicalToken":{
          "docindexfeature":"docindex",
          "get":[
            "surface",
          ],
          "start" : "",
          "end" : ""
        },
        "CenteredPsalmHeading" : {
           "docindexfeature" : "docindex",
           "start" : "",
           "end" : ""
        },
        "CenteredHeading" : {
           "docindexfeature" : "docindex",
           "get" : ["has_blank_line_before"],
           "start" : "",
           "end" : ""
        },
        "table" : {
           "docindexfeature" : "docindex",
           "end" : "</table>",
           "start" : "<table class=\"list\">"
        },
        "tr" : {
           "docindexfeature" : "docindex",
           "end" : "</tr>",
           "start" : "<tr class=\"list\">"
        },
        "td" : {
           "docindexfeature" : "docindex",
           "end" : "</td>",
           "get" : [
               "justification"
           ],
           "start" : "<td class=\"list {{ featurenomangle 0 }}-justified\">"
        },
        "th" : {
           "docindexfeature" : "docindex",
           "end" : "</th>",
           "start" : "<th class=\"list\">"
        },
        "Poetry" : {
           "docindexfeature" : "docindex",
           "end" : "",
           "get" : [
              "is_indented"
           ],
           "start" : ""
        },
        "Stanza" : {
           "docindexfeature" : "docindex",
           "end" : "",
           "get" : ["is_first_in_poetry_section"],
           "start" : ""

        },
        "PoetryLine" : {
           "docindexfeature" : "docindex",
           "end" : "</p>\n",
           "start" : "<p class=\"textPoetry\">"

        },
        "VerseNumberToken":{
          "docindexfeature":"docindex",
          "end":"&#160;",
          "get":[
            "surface",
          ],
          "start":"<a id=\"{{ emitvar 'verse_anchor' }}\" class=\"textVerse\">{{ featurenomangle 0 }}</a>"
        },
        "Verse":{
          "docindexfeature":"docindex",
          "end":"",
          "get":[
            "chapter",
            "verse_start"
          ],
          "start":"{{ setvar 'verse_anchor' }}verse-{{ featurenomangle 0 }}-{{ featurenomangle 1 }}{{ setvarend }}"
        },
        "Paragraph":{
          "docindexfeature":"docindex",
          "get":[
            "is_flush_left"
          ],
          "end":"</p>\n",
          "start" : "{{ if featureequal 0 'true' }}<p>{{ else }}<p class=\"textIndent\">{{ endif }}"
        },
        "ChapterNumberToken":{
          "docindexfeature":"docindex",
          "end":"",
          "get":[
            "surface",
          ],
          "start":"<a id=\"chapter-{{ feature 0 }}\" class=\"textChapter\">{{ featurenomangle 0 }}</a>"
        },
        "Token":{
          "docindexfeature":"docindex",
          "end":"",
          "get":[
            "surface",
          ],
          "start":"{{ feature 0 }}"
        },
        "NonWordToken":{
          "docindexfeature":"docindex",
          "end":"",
          "get":[
            "surface",
          ],
          "start":"{{ feature 0 }}"
        },
        "SpaceToken" : {
          "docindexfeature" : "docindex",
          "end" : "",
          "get" : [],
          "start" : " "
        }
      },
      "postprocess":[
        {
          "prefix":"<table class=\"\" style=\"transform: translate3d(0pt, 0px, 0px)\">\n"
        },
        {
          "suffix":"</table>"
        },
        {
          "instring": "</tr></p>",
          "outstring": "</tr>"
        },
        {
          "instring" : "&#160; ",
          "outstring" : "&#160;"
        }
      ]
    },
    "bookname":{
      "object_types":{
        "Book":{
          "docindexfeature":"docindex",
          "end":"",
          "get":[
            "DJHRef"
          ],
          "start":"{{ featurenomangle 0 }}"
        }
      },
      "prepend_XML_declaration":false
    }
  },
  "renderinfo":{
    "base":{
      "elements":{
        "blah":{
          "end":"</blah>",
          "start":"<blah>"
        }
      },
      "extends":"base",
      "fetch_stylesheet":"base"
    }
  }
}
