{
  "base" : {
    "object_types": {
      "Book" : {
         "docindexfeature": "docindex",
         "end": "",
         "start": "{{ setvar 'TextKind' }}Prose{{ setvarend }}",
      },
      "Source": {
        "docindexfeature": "docindex",
        "get": [ "source_color" ],
        "start": "{{ setvar 'source_color' }}{{ feature 0 }}{{ setvarend }}<Text {style: [styles.scripture, styles.sourceColor{{ emitvar 'source_color' }}]}, ",
        "end": "</Text>,",
      },
      "VerseNumberToken": {
        "docindexfeature" : "docindex",
        "get": [ "pre", "surface" ],
        "start": "<VerseNumber {style: styles.sourceColor{{ emitvar 'source_color' }}}, \"{{ featurenomangle 0 }}{{ featurenomangle 1 }}\"/>,",
        "end": "",
      },
      "Verse" : {
         "docindexfeature" : "docindex",
         "get" : [ "chapter", "verse_start" ],
         "start": "<Verse {style: styles.sourceColor{{ emitvar 'source_color' }}},",
         "end": "</Verse>,",
      },
      "Paragraph" : {
         "docindexfeature" : "docindex",
         "get" : [ "is_flush_left" ],
         "start": "<Paragraph null,",
         "end": "</Paragraph>,",
      },
      "Token": {
        "docindexfeature" : "docindex",
        "get": [ "pre", "surface", "post" ],
        "start": "\"{{ featurenomangle 0 }}{{ featurenomangle 1 }}{{ featurenomangle 2 }}\",",
        "end": "",
      },
      "NonWordToken": {
        "docindexfeature" : "docindex",
        "get": [ "pre", "surface", "post" ],
        "start": "\"{{ featurenomangle 0 }}{{ featurenomangle 1 }}{{ featurenomangle 2 }}\",",
        "end": "",
      },
    },
    "postprocess" : [
      {"instring": "<Paragraph ", "outstring": "React.createElement(Paragraph, "},
      {"instring": "</Paragraph>", "outstring": ")"},
      {"instring": "<Text ", "outstring": "React.createElement(Text, "},
      {"instring": "</Text>", "outstring": ")"},
      {"instring": "<VerseNumber ", "outstring": "React.createElement(VerseNumber, "},
      {"instring": "<Verse ", "outstring": "React.createElement(Verse, "},
      {"instring": "</Verse>", "outstring": ")"},
      {"instring": "/>", "outstring": ")"},
      {"instring" : ",)", "outstring" : ")"},
    ],
    "priority_list": [
    ],
    "prepend_XML_declaration" : false
  },
  "dictionaries": {
  }
}
