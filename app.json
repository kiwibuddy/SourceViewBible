{
  "expo": {
    "name": "SourceView Bible",
    "slug": "sourceview-bible",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "scheme": "sourceview",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sourceviewbible.SourceViewBible",
      "buildNumber": "2617",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "You can save your discoveries in your photos."
      }
    },
    "android": {
      "package": "com.sourceviewbible",
      "versionCode": 2617,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/sourceview.ttf"]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "befcb230-d453-4e7c-91f8-9053761722f3"
      },
      "router": {}
    },
    "updates": {
      "url": "https://u.expo.dev/befcb230-d453-4e7c-91f8-9053761722f3"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "owner": "kiwibuddy"
  }
}
